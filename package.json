{
  "name": "ffweb-monorepo",
  "private": true,
  "workspaces": ["packages/*"],
  "engines": { "node": ">=22" },
  "devDependencies": {
    "typescript": "^5.5",
    "tsup": "^8",
    "vitest": "^2",
    "@playwright/test": "^1.48",
    "@types/node": "^22"
  },
  "scripts": {
    "build:lib": "npm run build -w @ffweb/ffmpeg",
    "test:smoke": "node --test 'tests/smoke/*.test.mjs'",
    "test:unit": "vitest run",
    "test:node": "node --test 'tests/node/**/*.mjs'",
    "test:browser": "playwright test"
  }
}
